# ── Reasoning provider ────────────────────────────────────────────────
# qwen   = Alibaba Qwen via the hackathon endpoint (DEFAULT, sponsor-aligned)
# claude = Anthropic Claude (fallback)
LLM_PROVIDER=qwen

# Qwen (hackathon endpoint, OpenAI-compatible)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://hackathon.bitgetops.com/v1
QWEN_MODEL=qwen3.6-plus
QWEN_FAST_MODEL=qwen3.6-flash

# Anthropic (fallback — optional)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Bitget API (OPTIONAL — paper mode uses public market data, no keys needed) ──
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
BITGET_AGENT_HUB_ENABLED=true
REAL_TRADING_ENABLED=false

# Bitget Playbook API key (for getagent backtests — optional)
PLAYBOOK_API_KEY=

# Sentiment & news perception
USE_SENTIMENT=true
# Fear & Greed, GDELT news, and public crypto RSS feeds need no key.
# CryptoPanic is optional; if you have a token, VesperClaw will use its
# community-voted crypto headlines first.
CRYPTOPANIC_TOKEN=

# Prediction-market paper mode (Polymarket read feed, no wallet)
PRED_TARGET_ACCURACY=0.90
PRED_MIN_CONFIDENCE=0.70
PRED_EDGE_THRESHOLD=0.10
PRED_MAX_POSITIONS=3
PRED_SIZE_PCT=0.05
PRED_INCLUDE_WORLD_CUP=true
PRED_WORLD_CUP_MARKETS=6
PRED_INCLUDE_FOOTBALL=true
PRED_FOOTBALL_MARKETS=4

# ── Trading config ────────────────────────────────────────────────────
SYMBOL=BTC/USDT
TIMEFRAME=15m
INITIAL_BALANCE=10000
RISK_PER_TRADE=0.01

# Profit Guard: tighten after loss clusters / drawdown
PROFIT_GUARD_ENABLED=true
PROFIT_GUARD_LOSS_STREAK=2
PROFIT_GUARD_COOLDOWN_BARS=24
PROFIT_GUARD_MIN_CONFIDENCE_BONUS=0.15
PROFIT_GUARD_MAX_SIZE_PCT=0.035
PROFIT_GUARD_DRAWDOWN_PCT=0.01
PROFIT_GUARD_DAILY_LOSS_PCT=0.005
PROFIT_GUARD_BLOCK_REGIMES=uncertain

# Run mode: live_paper (15m cycles) or fast_demo (1m / replay, condensed)
RUN_MODE=fast_demo

# Use generated/replay data instead of the live Bitget feed (offline testing)
DEMO_DATA=false
